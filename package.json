{
  "name": "solodex",
  "version": "1.8.3",
  "description": "Pokemon solo challenge reference app",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:mac": "npm run build && electron-builder --mac --publish never",
    "build:release": "node scripts/release.js"
  },
  "build": {
    "appId": "com.solodex.app",
    "productName": "Solodex",
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.reference",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "files": [
      "out/**/*",
      "data_objects-main/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Scotts-Thoughts",
        "repo": "solodex"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "html-to-image": "^1.11.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
